# OGame AGI Configuration Template
# Copy this file to .env and fill in your credentials

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# OGame Account Configuration
OGAME_USERNAME=your_username_here
OGAME_PASSWORD=your_password_here
OGAME_EMAIL=your_email_here
OGAME_UNIVERSE_URL=https://your-universe.ogame.gameforge.com/game/index.php?page=ingame&component=overview
OGAME_UNIVERSE=your_universe_name

# Strategic Configuration
STRATEGIC_MODE=conservative
DECISION_INTERVAL=300
SESSION_DURATION=7200
MAX_ACTIONS_PER_CYCLE=3

# Security Settings
DEBUG=false
HEADLESS=true
LOG_LEVEL=INFO

# Conservative settings for safe gameplay
ACTION_DELAY_MIN=2000
ACTION_DELAY_MAX=5000
RANDOMIZE_BEHAVIOR=true
RISK_TOLERANCE=low

# Learning mode settings
STRATEGY_FOCUS=balanced
GAME_PHASE=early
AUTO_FLEETSAVE=true