# Environment variables template
# Copy to .env and fill in your values

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# OGame Configuration  
OGAME_UNIVERSE_URL=https://s1-en.ogame.gameforge.com/game/index.php
OGAME_USERNAME=your_ogame_username
OGAME_PASSWORD=your_ogame_password

# Agent Configuration
DEBUG=false
HEADLESS=true
LOG_LEVEL=INFO

# Behavioral Settings
ACTION_DELAY_MIN=1000  # milliseconds
ACTION_DELAY_MAX=3000  # milliseconds
RANDOMIZE_BEHAVIOR=true